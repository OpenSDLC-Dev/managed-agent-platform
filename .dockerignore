# Keep the build context small and secrets out of the image. The Dockerfile uses
# COPY . ., so secret-file patterns are depth-matched (**/) to keep any .gitignored
# local secret — at any level — out of the build context and its cache.
.git
.github
# Parallel-session worktrees: each is a whole extra checkout under the repo
# root, and compose builds with context ../.., so without this every live
# worktree is swept into the build context. The secret patterns below already
# depth-match, so nothing leaked — this is about context size and stale
# artifacts (coverage.out below is root-only).
.claude/worktrees
**/.env
**/.env.*
**/*.local.yaml
**/*.local.yml
**/model-providers.json
deploy/helm
deploy/compose
*.md
coverage.out
*.cov
