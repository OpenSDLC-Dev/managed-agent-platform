# Build output
/bin/
/dist/
*.exe

# Go test / coverage artifacts
*.test
*.out
coverage.*

# Go workspace files (local-only)
go.work
go.work.sum

# Local configuration and secrets — never commit these
.env
.env.*
*.local.yaml
*.local.yml
# ...but keep the committed templates, and ignore any real model-providers.json
# (a filled-in copy carries a live api_key) wherever it is created.
!.env.example
model-providers.json

# Tooling caches
.impeccable/

# Editors / OS
.idea/
.vscode/
.DS_Store

# Claude Code personal settings (the shared .claude/settings.json IS committed)
.claude/settings.local.json
.claude/scheduled_tasks.lock
# Parallel-session worktrees live here; without this every worktree's checkout
# shows up as untracked files in the main one. See .worktreeinclude.
.claude/worktrees/
