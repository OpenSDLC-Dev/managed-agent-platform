# Copy to .env and edit. docker compose reads it automatically. Never commit .env.

# Bootstrap management API key the real `ant` CLI / SDKs send as x-api-key. Required.
CONTROLPLANE_API_KEY=local-dev-key

# Postgres password for the bundled database. It is embedded in DATABASE_URL, so
# keep it URL-safe (no @ : / ? # % or spaces); any such value works, it is used
# only inside the stack.
POSTGRES_PASSWORD=map

# Host port the controlplane is published on (container always listens on 8080).
CONTROLPLANE_PORT=8080

# Interface the controlplane port binds to. Loopback by default so the API — which
# accepts the placeholder key above — is not reachable from the network. Set to
# 0.0.0.0 only with a real CONTROLPLANE_API_KEY.
# CONTROLPLANE_BIND=127.0.0.1

# Base image the executor uses for per-session sandbox containers.
EXECUTOR_IMAGE=debian:stable-slim

# Brain model routing. Defaults to the committed model-providers.example.json (so
# the stack starts out of the box, idling). To use your endpoint:
#   cp model-providers.example.json model-providers.json   # then edit it
#   MODEL_PROVIDERS_FILE=model-providers.json              # uncomment below
# MODEL_PROVIDERS_FILE=model-providers.json

# Traces: uncomment both and run `docker compose --profile observability up` to
# send spans to the bundled Jaeger (UI at http://localhost:16686). INSECURE=true
# is correct for the local plaintext Jaeger; leave it false for a TLS collector.
# OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317
# OTEL_EXPORTER_OTLP_INSECURE=true
